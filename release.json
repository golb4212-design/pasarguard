{
  "version": "2.9.1",
  "architecture": "fully-split-three-worker",
  "files": {
    "core": "core/worker.js",
    "edge": "edge/worker.js",
    "processor": "processor/worker.js"
  },
  "roles": {
    "core": "central bot, finance, licenses, central APIs and D1 authority",
    "edge": "all web pages, reseller bots, customer miniapps and reseller management",
    "processor": "queues, scheduled reseller automation and background jobs"
  },
  "bindings": {
    "core": [
      "PASARGUARD_DB",
      "EDGE_WORKER",
      "PROCESSOR_WORKER"
    ],
    "edge": [
      "EDGE_DB",
      "CORE_WORKER",
      "PROCESSOR_WORKER"
    ],
    "processor": [
      "PROCESSOR_DB",
      "CORE_WORKER",
      "EDGE_WORKER"
    ]
  },
  "remote_d1": "service-binding-only",
  "request_update_checks": false
}
